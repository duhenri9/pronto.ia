# ============================================
# PRONTO.IA — Environment Configuration
# ============================================

# General
NODE_ENV=development
LOG_LEVEL=debug

# Database (PostgreSQL)
DATABASE_URL=postgresql://pronto:pronto@localhost:5432/pronto_ia

# Auth (jose HS256)
JWT_SECRET=pronto-ia-dev-secret-change-in-production
COOKIE_SECRET=pronto-ia-dev-cookie-secret-change-in-prod

# Web (Next.js)
PORT=3000
CORS_ORIGIN=http://localhost:3000

# Redis (async queue + cache)
REDIS_URL=redis://localhost:6379

# WhatsApp — Cloud API (production) or Z-API (pilot)
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_PROVIDER=zapi   # "zapi" for pilot (<1k students), "cloud_api" for scale

# Z-API (pilot)
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_SECURITY_TOKEN=

# AI / LLM — Anthropic Claude Direct
ANTHROPIC_API_KEY=
AI_DEFAULT_MODEL=claude-haiku-4-5-20251001
AI_EVALUATION_MODEL=claude-sonnet-4-5-20250514
AI_DEFAULT_MAX_TOKENS=800
AI_COST_PER_1K_INPUT_CENTS=0.80
AI_COST_PER_1K_OUTPUT_CENTS=4.00

# Payments (Abacate Pay + Stripe — ADR-0012)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
ABACATE_PAY_API_KEY=
ABACATE_PAY_WEBHOOK_SECRET=

# B2C Pro pricing
PRO_MONTHLY_PRICE_CENTS=1900

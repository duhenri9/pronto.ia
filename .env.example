# -- Banco de Dados (Neon, PostgreSQL 16, regiao sa-east-1) --
DATABASE_URL=postgresql://<user>:<pass>@ep-<id>.sa-east-1.aws.neon.tech/pronto_ia?sslmode=require&channel_binding=require

# -- Redis (Upstash, regiao sa-east-1) --
REDIS_URL=redis://default:<password>@<host>:6379

# -- Anthropic (provider principal atual) --
ANTHROPIC_API_KEY=sk-ant-...

# -- Seletor do provider de WhatsApp --
# MVP: use "zapi"
# Pos-MVP / oficial Meta: use "cloud_api"
WHATSAPP_PROVIDER=zapi

# -- WhatsApp MVP com Z-API --
ZAPI_INSTANCE_ID=instance_...
ZAPI_TOKEN=token_...
ZAPI_SECURITY_TOKEN=security_token_...

# -- WhatsApp transicao / Meta Cloud API --
# Estes sao os nomes canonicamente usados no codigo hoje.
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=<uuid-aleatorio>
WHATSAPP_APP_SECRET=

# -- Compatibilidade legada Meta --
# Ainda aceitos pelo codigo para facilitar migracao, mas prefira WHATSAPP_*.
META_WHATSAPP_ACCESS_TOKEN=
META_WHATSAPP_PHONE_NUMBER_ID=

# -- Seguranca --
JWT_SECRET=<jwt-secret-aqui>
COOKIE_SECRET=<cookie-secret-aqui>
ADMIN_SECRET=<admin-secret-aqui>

# -- Pagamento --
ABACATE_PAY_API_KEY=
NEXT_PUBLIC_BASE_URL=https://pronto-ia.vercel.app

# -- Observabilidade --
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=sntrys_...

# -- Email transacional --
RESEND_API_KEY=re_...

# -- Rate limit / allowlist --
RATE_LIMIT_ALLOWLIST=5511XXXXXXXXX,5511YYYYYYYYY

# -- Google AI (opcional) --
GOOGLE_AI_API_KEY=

# -- LLM feature flags --
LLM_PROVIDER_PRIMARY=anthropic
LLM_PROVIDER_FALLBACK=openai
LLM_FALLBACK_ENABLED=false

# -- Cambio para custo LLM (centavos de BRL por USD) --
USD_TO_BRL_CENTS=550

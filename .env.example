# ── Banco de Dados (Neon, PostgreSQL 16, região sa-east-1) ──
DATABASE_URL=postgresql://<user>:<pass>@ep-<id>.sa-east-1.aws.neon.tech/pronto_ia?sslmode=require

# ── Redis (Railway, plugin nativo) ──
REDIS_URL=redis://default:<senha>@<host>.railway.internal:6379

# ── Anthropic (Haiku 4.5 + Sonnet 4.5, sem intermediários) ──
ANTHROPIC_API_KEY=sk-ant-...
AI_DEFAULT_MODEL=claude-haiku-4-5-20251001
AI_EVALUATION_MODEL=claude-sonnet-4-5-20250514
AI_DEFAULT_MAX_TOKENS=800
USD_TO_BRL_CENTS=550
AI_COST_PER_1K_INPUT_CENTS=0.80
AI_COST_PER_1K_OUTPUT_CENTS=4.00

# ── WhatsApp (Z-API, provider primário para MVP) ──
WHATSAPP_PROVIDER=zapi
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_SECURITY_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# ── Meta Cloud API (fallback futuro, opcional) ──
WHATSAPP_APP_SECRET=
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# ── Segurança ──
JWT_SECRET=
COOKIE_SECRET=

# ── Pagamentos (Abacate Pay + Stripe — ADR-0012) ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
ABACATE_PAY_API_KEY=
ABACATE_PAY_WEBHOOK_SECRET=

# ── Observabilidade (Sentry, plano grátis) ──
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ── Pricing ──
PRO_MONTHLY_PRICE_CENTS=1900
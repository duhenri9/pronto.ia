{
  "name": "@pronto-ia/worker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && copyfiles -u 2 ../../prompts/personas/*.md dist/prompts/personas/",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run"
  },
  "dependencies": {
    "@pronto-ia/database": "workspace:*",
    "@pronto-ia/events": "workspace:*",
    "@pronto-ia/llm": "workspace:*",
    "@pronto-ia/types": "workspace:*",
    "@pronto-ia/whatsapp": "workspace:*",
    "@sentry/node": "^10.51.0",
    "bullmq": "^5.13.0",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.44.0",
    "ioredis": "^5.4.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "copyfiles": "^2.4.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.5"
  }
}
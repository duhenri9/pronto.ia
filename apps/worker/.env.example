# ============================================
# PRONTO.IA Worker — Environment Configuration
# ============================================

# Database
DATABASE_URL=postgresql://pronto:pronto@localhost:5432/pronto_ia

# Redis
REDIS_URL=redis://localhost:6379

# Anthropic
ANTHROPIC_API_KEY=

# WhatsApp Provider
WHATSAPP_PROVIDER=zapi
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# Z-API (pilot)
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_SECURITY_TOKEN=

# LLM
AI_DEFAULT_MODEL=claude-haiku-4-5-20251001
AI_EVALUATION_MODEL=claude-sonnet-4-5-20250514
AI_DEFAULT_MAX_TOKENS=800

# Prompts directory — MUST be set in Railway deployment
# In dev: defaults to ../../prompts/personas (relative to src/)
# In Railway: set to ./dist/src/prompts/personas
PROMPTS_DIR=

# Sentry
SENTRY_DSN=
{
  "name": "pronto-ia",
  "version": "0.1.0",
  "private": true,
  "description": "Pronto.IA - Plataforma Nacional de Treinamento em IA para MEIs",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "rm -rf apps/*/.next apps/*/dist packages/*/.next packages/*/dist node_modules/.cache",
    "build:clean": "pnpm clean && pnpm install && pnpm build",
    "db:generate": "turbo run db:generate",
    "db:migrate": "turbo run db:migrate",
    "test:ci": "turbo run typecheck lint test:unit",
    "test:unit": "turbo run test:unit"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.5"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
